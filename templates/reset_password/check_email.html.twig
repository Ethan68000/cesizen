{% extends 'base.html.twig' %}

{% block title %}Email envoyé — CESIZen{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

        <div class="form-cesizen shadow text-center">
            <i class="bi bi-envelope-check-fill display-3 text-success mb-3"></i>
            <h1 class="h4 fw-bold mb-3">Email envoyé !</h1>
            <p class="text-muted">
                Si un compte correspond à votre adresse email, un lien de réinitialisation vient d'être envoyé.
                Ce lien expirera dans
                <strong>{{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}</strong>.
            </p>
            <hr>
            <p class="text-muted small">
                Vous n'avez pas reçu d'email ? Vérifiez vos spams ou
                <a href="{{ path('app_forgot_password_request') }}">réessayez</a>.
            </p>
        </div>

        <div class="text-center mt-3">
            <a href="{{ path('app_login') }}" class="text-white">
                <i class="bi bi-arrow-left me-1"></i> Retour à la connexion
            </a>
        </div>

    </div>
</div>
{% endblock %}