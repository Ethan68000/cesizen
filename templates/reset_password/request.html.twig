{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié — CESIZen{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

        <div class="text-center mb-4">
            <i class="bi bi-lock-fill display-4 text-white"></i>
            <h1 class="h3 fw-bold text-white mt-2">Mot de passe oublié ?</h1>
            <p class="text-white-50">Entrez votre email et nous vous enverrons un lien de réinitialisation.</p>
        </div>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
        {% endfor %}

        <div class="form-cesizen shadow">
            {{ form_start(requestForm) }}
                <div class="mb-4">
                    {{ form_label(requestForm.email) }}
                    {{ form_widget(requestForm.email, {'attr': {'class': 'form-control', 'placeholder': 'votre@email.fr'}}) }}
                    {{ form_errors(requestForm.email) }}
                </div>

                <button class="btn btn-cesizen-primary w-100">
                    <i class="bi bi-envelope me-2"></i> Envoyer le lien de réinitialisation
                </button>
            {{ form_end(requestForm) }}
        </div>

        <div class="text-center mt-3">
            <a href="{{ path('app_login') }}" class="text-white">
                <i class="bi bi-arrow-left me-1"></i> Retour à la connexion
            </a>
        </div>

    </div>
</div>
{% endblock %}