<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}CESIZen{% endblock %}</title>

        <!-- Bootstrap 5 -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Bootstrap Icons -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

        <style>
            :root {
                --cesizen-blue: #004aad;
                --cesizen-purple: #7b3fb5;
                --cesizen-white: #ffffff;
                --cesizen-light: #f0f4ff;
                --cesizen-dark: #1a1a2e;
            }

            body {
                background: linear-gradient(135deg, #004aad 0%, #7b3fb5 100%);
                min-height: 100vh;
                font-family: 'Segoe UI', sans-serif;
                color: #fff;
            }

            /* NAVBAR */
            .navbar-cesizen {
                background: rgba(0, 0, 0, 0.4);
                backdrop-filter: blur(12px);
                border-bottom: 2px solid rgba(255,255,255,0.2);
            }

            .navbar-cesizen .navbar-brand {
                color: #fff !important;
                font-weight: 700;
                font-size: 1.4rem;
            }

            .navbar-cesizen .nav-link {
                color: #fff !important;
                font-weight: 500;
                padding: 8px 14px;
                border-radius: 8px;
                transition: background 0.2s;
            }

            .navbar-cesizen .nav-link:hover,
            .navbar-cesizen .nav-link:focus {
                background: rgba(255,255,255,0.2);
                color: #fff !important;
                outline: 2px solid rgba(255,255,255,0.5);
            }

            /* CARDS */
            .card-cesizen {
                background: rgba(255, 255, 255, 0.12);
                backdrop-filter: blur(10px);
                border: 1.5px solid rgba(255,255,255,0.3);
                border-radius: 16px;
                color: #fff;
                transition: transform 0.2s, box-shadow 0.2s;
            }

            .card-cesizen:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            }

            /* BANNER */
            .section-banner {
                background: rgba(255,255,255,0.15);
                backdrop-filter: blur(8px);
                border: 1.5px solid rgba(255,255,255,0.3);
                border-radius: 16px;
                color: #fff;
                padding: 1.5rem 2rem;
                margin-bottom: 2rem;
            }

            /* FORMULAIRES */
            .form-cesizen {
                background: rgba(255,255,255,0.95);
                border-radius: 16px;
                padding: 2rem;
                color: #1a1a2e;
            }

            .form-cesizen label {
                font-weight: 600;
                color: #1a1a2e;
                margin-bottom: 4px;
            }

            .form-cesizen .form-control {
                border: 2px solid #ccc;
                border-radius: 8px;
                padding: 10px 14px;
                font-size: 1rem;
                color: #1a1a2e;
            }

            .form-cesizen .form-control:focus {
                border-color: var(--cesizen-blue);
                box-shadow: 0 0 0 3px rgba(0,74,173,0.2);
                outline: none;
            }

            .form-cesizen .invalid-feedback,
            .form-cesizen ul.list-unstyled {
                color: #c0392b;
                font-weight: 500;
            }

            /* BOUTONS */
            .btn-cesizen {
                background: rgba(255,255,255,0.2);
                border: 2px solid rgba(255,255,255,0.6);
                color: #fff;
                border-radius: 8px;
                padding: 8px 18px;
                font-weight: 500;
                transition: background 0.2s;
            }

            .btn-cesizen:hover, .btn-cesizen:focus {
                background: rgba(255,255,255,0.35);
                color: #fff;
                outline: 2px solid #fff;
            }

            .btn-cesizen-primary {
                background: #fff;
                border: 2px solid #fff;
                color: var(--cesizen-blue);
                border-radius: 8px;
                padding: 8px 24px;
                font-weight: 700;
                transition: background 0.2s;
            }

            .btn-cesizen-primary:hover, .btn-cesizen-primary:focus {
                background: #e0ecff;
                color: var(--cesizen-blue);
                outline: 2px solid var(--cesizen-blue);
            }

            .btn-cesizen-danger {
                background: #c0392b;
                border: 2px solid #c0392b;
                color: #fff;
                border-radius: 8px;
                padding: 8px 18px;
                font-weight: 600;
                transition: background 0.2s;
            }

            .btn-cesizen-danger:hover, .btn-cesizen-danger:focus {
                background: #922b21;
                border-color: #922b21;
                color: #fff;
                outline: 2px solid #fff;
            }

            /* INPUT FILE */
            .input-file-cesizen {
                background: rgba(255,255,255,0.9);
                border: 2px solid rgba(255,255,255,0.6);
                border-radius: 8px;
                color: #1a1a2e;
                padding: 6px 12px;
                font-size: 0.9rem;
            }

            /* FOOTER */
            footer {
                background: rgba(0,0,0,0.3);
                color: rgba(255,255,255,0.9);
                text-align: center;
                padding: 1rem;
                margin-top: 3rem;
                border-top: 1px solid rgba(255,255,255,0.15);
            }

            /* TABLES */
            .table-cesizen {
                background: rgba(255,255,255,0.95);
                border-radius: 12px;
                overflow: hidden;
                color: #1a1a2e;
            }

            .table-cesizen th {
                background: #004aad;
                color: #fff;
                font-weight: 600;
                padding: 12px 16px;
            }

            .table-cesizen td {
                padding: 12px 16px;
                border-bottom: 1px solid #e0e0e0;
                vertical-align: middle;
            }

            /* LIENS */
            a {
                color: #fff;
            }

            a:hover {
                color: #e0c9ff;
            }
        </style>

        {% block stylesheets %}{% endblock %}
    </head>
    <body>

        <!-- Navbar -->
        <nav class="navbar navbar-expand-lg navbar-cesizen shadow-sm">
            <div class="container">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <i class="bi bi-wind"></i> CESIZen
                </a>
                <button class="navbar-toggler border-white" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Menu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMenu">
                    <ul class="navbar-nav ms-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_informations_index') }}">
                                <i class="bi bi-info-circle" aria-hidden="true"></i> Informations
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_exercice_respiration_index') }}">
                                <i class="bi bi-lungs" aria-hidden="true"></i> Exercices de respiration
                            </a>
                        </li>
                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_logout') }}">
                                    <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
                                    Déconnexion <span class="fw-bold">({{ app.user.userIdentifier }})</span>
                                </a>
                            </li>
                            {% if is_granted('ROLE_ADMIN') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('admin') }}">
                                    <i class="bi bi-gear" aria-hidden="true"></i> Admin
                                </a>
                            </li>
                            {% endif %}
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login') }}">
                                    <i class="bi bi-person" aria-hidden="true"></i> Connexion
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <!-- Contenu principal -->
        <main class="container py-4" id="main-content">

            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'success' ? 'success' : (type == 'warning' ? 'warning' : 'danger') }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer>
            <p class="mb-0">© 2024 CESIZen — L'application de votre santé mentale</p>
        </footer>

        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>