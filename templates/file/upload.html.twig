{% extends 'base.html.twig' %}

{% block title %}Ajouter un fichier — {{ informations.title }}{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">

        <div class="d-flex align-items-center mb-4">
            <a href="{{ path('app_informations_show', {id: informations.id}) }}" class="btn-cesizen btn me-3">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Retour
            </a>
            <h1 class="h3 fw-bold mb-0">
                <i class="bi bi-upload me-2"></i>Ajouter un fichier
            </h1>
        </div>

        <div class="form-cesizen shadow">
            <p class="text-muted mb-4">
                Vous ajoutez un fichier à l'information : <strong>{{ informations.title }}</strong>
            </p>

            <form method="post" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('upload') }}">

                <div class="mb-4">
                    <label for="file" class="form-label fw-bold">
                        <i class="bi bi-paperclip me-1"></i> Choisir un fichier
                    </label>
                    <input type="file"
                           name="file"
                           id="file"
                           class="form-control"
                           accept=".jpg,.jpeg,.png,.gif,.webp,.pdf,.mp4,.mpeg,.mov,.webm"
                           required
                           aria-describedby="fileHelp">
                    <div id="fileHelp" class="form-text text-muted mt-2">
                        <i class="bi bi-info-circle me-1"></i>
                        Formats acceptés : JPEG, PNG, GIF, WEBP, PDF, MP4, MPEG, MOV, WEBM
                    </div>
                </div>

                <button type="submit" class="btn btn-cesizen-primary w-100">
                    <i class="bi bi-cloud-upload me-2"></i> Uploader le fichier
                </button>
            </form>
        </div>

    </div>
</div>
{% endblock %}