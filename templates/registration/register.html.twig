{% extends 'base.html.twig' %}

{% block title %}Inscription — CESIZen{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">

        <div class="text-center mb-4">
            <i class="bi bi-person-plus-fill display-4 text-white"></i>
            <h1 class="h3 fw-bold text-white mt-2">Créer un compte</h1>
        </div>

        <div class="form-cesizen shadow">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="mb-3">
                {{ form_label(form.pseudo) }}
                {{ form_widget(form.pseudo, {'attr': {'class': 'form-control', 'placeholder': 'Votre pseudo'}}) }}
                {{ form_errors(form.pseudo) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'votre@email.fr'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.birthdate) }}
                {{ form_widget(form.birthdate, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.birthdate) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first, {'attr': {'class': 'form-control', 'placeholder': '12 caractères min.'}}) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>

            <div class="mb-4">
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second, {'attr': {'class': 'form-control', 'placeholder': 'Confirmez le mot de passe'}}) }}
                {{ form_errors(form.plainPassword.second) }}
            </div>

            <small class="text-muted d-block mb-3">
                <i class="bi bi-info-circle me-1"></i>
                12 caractères min, 1 majuscule, 1 minuscule, 1 chiffre, 1 caractère spécial.
            </small>

            <button type="submit" class="btn btn-cesizen-primary w-100">
                <i class="bi bi-person-check me-2"></i> S'inscrire
            </button>

            {{ form_end(form) }}
        </div>

        <p class="text-center mt-3 text-white">
            Déjà un compte ? <a href="{{ path('app_login') }}" class="fw-bold text-white">Se connecter</a>
        </p>

    </div>
</div>
{% endblock %}