{% extends 'base.html.twig' %}

{% block title %}{{ information.title }}{% endblock %}

{% block body %}
    <h1>{{ information.title }}</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ information.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ information.title }}</td>
            </tr>
            <tr>
                <th>Slug</th>
                <td>{{ information.slug }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ information.description }}</td>
            </tr>
            <tr>
                <th>Date de création</th>
                <td>{{ information.creationDate ? information.creationDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <!-- Fichiers associés -->
    <h2 class="mt-4">Fichiers</h2>

    {% if information.files is not empty %}
        <table class="table">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Fichier</th>
                    {% if is_granted('ROLE_ADMIN') %}
                        <th>Action</th>
                    {% endif %}
                </tr>
            </thead>
            <tbody>
                {% for file in information.files %}
                <tr>
                    <td>{{ file.type }}</td>
                    <td>
                        {% if 'image' in file.type %}
                            <img src="{{ asset('uploads/' ~ file.path) }}" style="max-height: 100px;">
                        {% elseif 'pdf' in file.type %}
                            <a href="{{ asset('uploads/' ~ file.path) }}" target="_blank">Voir le PDF</a>
                        {% elseif 'video' in file.type %}
                            <video src="{{ asset('uploads/' ~ file.path) }}" controls style="max-height: 100px;"></video>
                        {% else %}
                            <a href="{{ asset('uploads/' ~ file.path) }}" target="_blank">Télécharger</a>
                        {% endif %}
                    </td>
                    {% if is_granted('ROLE_ADMIN') %}
                    <td>
                        <form method="post" action="{{ path('app_file_delete', {id: file.id}) }}" onsubmit="return confirm('Supprimer ce fichier ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ file.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                        </form>
                    </td>
                    {% endif %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p class="text-muted">Aucun fichier associé.</p>
    {% endif %}

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_file_upload', {id: information.id}) }}" class="btn btn-success mb-3">
            Ajouter un fichier
        </a>
    {% endif %}

    <hr>
    <a href="{{ path('app_informations_index') }}">Retour à la liste</a>

    {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('app_informations_edit', {'id': information.id}) }}">Modifier</a>
        {{ include('informations/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}