{% extends 'base.html.twig' %}

{% block title %}{{ information.title }} — CESIZen{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">

        <div class="d-flex align-items-center mb-4">
            <a href="{{ path('app_informations_index') }}" class="btn-cesizen btn me-3">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Retour
            </a>
            <h1 class="h3 fw-bold mb-0">{{ information.title }}</h1>
        </div>

        <div class="form-cesizen shadow mb-4">
            <p class="text-muted small mb-3">
                <i class="bi bi-calendar me-1"></i>
                Publié le {{ information.creationDate|date('d/m/Y') }}
            </p>
            <p class="fs-5" style="line-height: 1.8;">{{ information.description }}</p>
        </div>

        <!-- Fichiers -->
        <h2 class="h4 fw-bold mb-3">
            <i class="bi bi-paperclip me-2"></i>Fichiers associés
        </h2>

        {% if information.files is not empty %}
        <div class="form-cesizen shadow mb-4">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Aperçu / Lien</th>
                        {% if is_granted('ROLE_ADMIN') %}
                        <th>Action</th>
                        {% endif %}
                    </tr>
                </thead>
                <tbody>
                    {% for file in information.files %}
                    <tr>
                        <td>{{ file.type }}</td>
                        <td>
                            {% if 'image' in file.type %}
                                <img src="{{ asset('uploads/' ~ file.path) }}" alt="Image" style="max-height: 80px; border-radius: 8px;">
                            {% elseif 'pdf' in file.type %}
                                <a href="{{ asset('uploads/' ~ file.path) }}" target="_blank" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-file-pdf me-1"></i> Voir le PDF
                                </a>
                            {% elseif 'video' in file.type %}
                                <video src="{{ asset('uploads/' ~ file.path) }}" controls style="max-height: 80px; border-radius: 8px;"></video>
                            {% else %}
                                <a href="{{ asset('uploads/' ~ file.path) }}" target="_blank" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-download me-1"></i> Télécharger
                                </a>
                            {% endif %}
                        </td>
                        {% if is_granted('ROLE_ADMIN') %}
                        <td>
                            <form method="post" action="{{ path('app_file_delete', {id: file.id}) }}"
                                  onsubmit="return confirm('Supprimer ce fichier ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ file.id) }}">
                                <button type="submit" class="btn btn-cesizen-danger btn-sm">
                                    <i class="bi bi-trash me-1"></i> Supprimer
                                </button>
                            </form>
                        </td>
                        {% endif %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
            <div class="section-banner mb-4">
                <p class="mb-0 text-center">
                    <i class="bi bi-folder2-open me-2"></i>Aucun fichier associé.
                </p>
            </div>
        {% endif %}

        <!-- Actions admin -->
        {% if is_granted('ROLE_ADMIN') %}
        <div class="d-flex gap-3 flex-wrap">
            <a href="{{ path('app_file_upload', {id: information.id}) }}" class="btn btn-cesizen-primary">
                <i class="bi bi-upload me-1"></i> Ajouter un fichier
            </a>
            <a href="{{ path('app_informations_edit', {id: information.id}) }}" class="btn btn-cesizen">
                <i class="bi bi-pencil me-1"></i> Modifier
            </a>
            <form method="post" action="{{ path('app_informations_delete', {id: information.id}) }}"
                  onsubmit="return confirm('Supprimer cette information ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ information.id) }}">
                <button type="submit" class="btn btn-cesizen-danger">
                    <i class="bi bi-trash me-1"></i> Supprimer
                </button>
            </form>
        </div>
        {% endif %}

    </div>
</div>
{% endblock %}