{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil — CESIZen{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">

        <div class="d-flex align-items-center mb-4">
            <a href="{{ path('app_user_space') }}" class="btn-cesizen btn me-3">
                <i class="bi bi-arrow-left" aria-hidden="true"></i> Retour
            </a>
            <h1 class="h3 fw-bold mb-0">
                <i class="bi bi-person-circle me-2"></i>Modifier mon profil
            </h1>
        </div>

        <div class="form-cesizen shadow">
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="mb-3">
                {{ form_label(form.pseudo) }}
                {{ form_widget(form.pseudo, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.pseudo) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="mb-4">
                {{ form_label(form.birthdate) }}
                {{ form_widget(form.birthdate, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.birthdate) }}
            </div>

            <button type="submit" class="btn btn-cesizen-primary w-100">
                <i class="bi bi-check-circle me-2"></i> Enregistrer les modifications
            </button>

            {{ form_end(form) }}
        </div>

        <!-- Supprimer le compte -->
        <div class="form-cesizen shadow mt-4">
            <h5 class="fw-bold text-danger mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>Zone dangereuse
            </h5>
            <p class="text-muted small mb-3">La suppression de votre compte est irréversible. Toutes vos données seront perdues.</p>
            <form method="post" action="{{ path('app_user_delete') }}"
                  onsubmit="return confirm('Supprimer votre compte ? Cette action est irréversible.');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_user') }}">
                <button type="submit" class="btn btn-cesizen-danger w-100">
                    <i class="bi bi-trash me-2"></i> Supprimer mon compte
                </button>
            </form>
        </div>

    </div>
</div>
{% endblock %}