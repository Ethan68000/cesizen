{% extends 'base.html.twig' %}

{% block title %}{{ exercice_respiration.nameSeries }} — CESIZen{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6 text-center">

        <h1 class="fw-bold mb-4 mt-5">{{ exercice_respiration.nameSeries }}</h1>

        <!-- Cercle animé -->
        <div class="my-5 d-flex justify-content-center">
            <div id="breathingCircle" style="
                width: 220px;
                height: 220px;
                border-radius: 50%;
                background: rgba(255,255,255,0.2);
                border: 4px solid rgba(255,255,255,0.6);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                transition: transform 1s ease-in-out, background 1s ease;
            ">
                <div id="phaseLabel" style="font-size: 1.4rem; font-weight: 700; color: #fff;"></div>
                <div id="countdown" style="font-size: 3rem; font-weight: 800; color: #fff;"></div>
            </div>
        </div>

        <p id="total" class="text-white-50 mb-4"></p>
        <p id="fin" class="fs-4 fw-bold text-white mb-4" style="display:none;"></p>

        <a href="{{ path('app_exercice_respiration_index') }}"
           onclick="running = false"
           class="btn btn-cesizen-danger px-4">
            <i class="bi bi-stop-fill me-2"></i> Arrêter et retourner aux exercices
        </a>

    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    const INSPIRATION = {{ exercice_respiration.timeInspiration }};
    const APNEA = {{ exercice_respiration.timeApnea }};
    const EXPIRATION = {{ exercice_respiration.timeExpiration }};
    const DUREE_TOTALE = 60;

    let tempsEcoule = 0;
    let running = true;

    const circle    = document.getElementById('breathingCircle');
    const phaseEl   = document.getElementById('phaseLabel');
    const countdownEl = document.getElementById('countdown');
    const totalEl   = document.getElementById('total');
    const finEl     = document.getElementById('fin');

    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function setPhase(label, scale, color) {
        phaseEl.textContent = label;
        circle.style.transform = `scale(${scale})`;
        circle.style.background = color;
    }

    function countdown(secondes, label, scale, color) {
        return new Promise(async (resolve) => {
            setPhase(label, scale, color);
            for (let i = secondes; i >= 1; i--) {
                if (!running) return resolve();
                countdownEl.textContent = i;
                tempsEcoule++;
                totalEl.textContent = 'Temps écoulé : ' + tempsEcoule + 's / ' + DUREE_TOTALE + 's';
                await sleep(1000);
            }
            resolve();
        });
    }

    async function run() {
        while (running && tempsEcoule < DUREE_TOTALE) {
            await countdown(INSPIRATION, 'Inspirez 🫁', 1.3, 'rgba(100,180,255,0.35)');
            if (!running || tempsEcoule >= DUREE_TOTALE) break;

            if (APNEA > 0) {
                await countdown(APNEA, 'Retenez 😶', 1.3, 'rgba(255,220,100,0.35)');
                if (!running || tempsEcoule >= DUREE_TOTALE) break;
            }

            await countdown(EXPIRATION, 'Expirez 💨', 1.0, 'rgba(100,255,180,0.25)');
        }

        running = false;
        circle.style.transform = 'scale(1)';
        circle.style.background = 'rgba(255,255,255,0.2)';
        phaseEl.textContent = '✅';
        countdownEl.textContent = '';
        totalEl.textContent = '';
        finEl.style.display = 'block';
        finEl.textContent = 'Exercice terminé ! Bravo 🌿';

        await sleep(3000);
        window.location.href = '{{ path('app_exercice_respiration_index') }}';
    }

    run();
</script>
{% endblock %}