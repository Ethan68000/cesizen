{% extends 'base.html.twig' %}

{% block title %}Lancement — {{ exercice_respiration.nameSeries }}{% endblock %}

{% block body %}
<div class="text-center py-5">
    <h1>Vous avez lancé l'exercice "{{ exercice_respiration.nameSeries }}"</h1>

    <div id="phase" class="display-4 fw-bold mt-4"></div>
    <div id="countdown" class="display-1 fw-bold text-success mt-3"></div>
    <div id="total" class="text-muted mt-2"></div>
    <div id="fin" class="display-5 text-success mt-4" style="display:none !important"></div>
</div>
<div class="d-flex justify-content-center mt-4">
    <a href="{{ path('app_exercice_respiration_index') }}" 
       onclick="running = false"
       class="btn btn-danger">
        Arrêter et retourner aux exercices
    </a>
</div>
{% endblock %}

{% block javascripts %}
<script>
    const INSPIRATION = {{ exercice_respiration.timeInspiration }};
    const APNEA = {{ exercice_respiration.timeApnea }};
    const EXPIRATION = {{ exercice_respiration.timeExpiration }};
    const DUREE_TOTALE = 60;

    let tempsEcoule = 0;
    let running = true;

    const phaseEl = document.getElementById('phase');
    const countdownEl = document.getElementById('countdown');
    const totalEl = document.getElementById('total');
    const finEl = document.getElementById('fin');

    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    function countdown(secondes, label) {
        return new Promise(async (resolve) => {
            phaseEl.textContent = label;
            for (let i = secondes; i >= 1; i--) {
                if (!running) return resolve();
                countdownEl.textContent = i;
                tempsEcoule++;
                totalEl.textContent = 'Temps écoulé : ' + tempsEcoule + 's / ' + DUREE_TOTALE + 's';
                await sleep(1000);
            }
            resolve();
        });
    }

    async function run() {
        while (running && tempsEcoule < DUREE_TOTALE) {
            await countdown(INSPIRATION, 'Inspirez');
            if (!running || tempsEcoule >= DUREE_TOTALE) break;

            if (APNEA > 0) {
                await countdown(APNEA, 'Apnée');
                if (!running || tempsEcoule >= DUREE_TOTALE) break;
            }

            await countdown(EXPIRATION, 'Expirez');
        }

        running = false;
        phaseEl.textContent = '';
        countdownEl.textContent = '';
        totalEl.textContent = '';
        finEl.style.display = 'block';
        finEl.textContent = 'Exercice terminé !';

        await sleep(3000);
        window.location.href = '{{ path('app_exercice_respiration_index') }}';
    }

    run();
</script>
{% endblock %}