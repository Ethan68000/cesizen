{% extends 'base.html.twig' %}

{% block title %}Exercices de respiration — CESIZen{% endblock %}

{% block body %}

    <!-- Banner -->
    <div class="section-banner text-center">
        <h1 class="fw-bold fs-2"><i class="bi bi-lungs me-2"></i>Exercices de respiration</h1>
        <p class="mb-0 fs-5">Vous êtes sur la page des exercices, découvrez nos contenus</p>
    </div>

    <!-- Export / Import admin seulement -->
    {% if is_granted('ROLE_ADMIN') %}
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <a href="{{ path('app_exercice_respiration_new') }}" class="btn btn-cesizen-primary">
            <i class="bi bi-plus-circle me-1"></i> Créer un exercice
        </a>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a href="{{ path('app_exercice_respiration_export') }}" class="btn btn-cesizen">
                <i class="bi bi-download me-1"></i> Exporter tout
            </a>
            <form method="post" action="{{ path('app_exercice_respiration_import') }}" enctype="multipart/form-data" class="d-flex gap-2">
                <input type="file" name="json_file" accept=".json" class="form-control form-control-sm" required>
                <button type="submit" class="btn btn-cesizen">
                    <i class="bi bi-upload me-1"></i> Importer
                </button>
            </form>
        </div>
    </div>
    {% endif %}

    <div class="row g-4">
        {% for exercice_respiration in exercice_respirations %}
        <div class="col-md-4">
            <div class="card card-cesizen h-100 p-3">
                <div class="card-body text-center">
                    <i class="bi bi-wind display-4 mb-2"></i>
                    <h5 class="fw-bold">{{ exercice_respiration.nameSeries }}</h5>
                    <div class="d-flex justify-content-around my-3">
                        <div>
                            <span class="d-block fs-4 fw-bold">{{ exercice_respiration.timeInspiration }}s</span>
                            <small style="opacity:0.75;">Inspiration</small>
                        </div>
                        {% if exercice_respiration.timeApnea > 0 %}
                        <div>
                            <span class="d-block fs-4 fw-bold">{{ exercice_respiration.timeApnea }}s</span>
                            <small style="opacity:0.75;">Apnée</small>
                        </div>
                        {% endif %}
                        <div>
                            <span class="d-block fs-4 fw-bold">{{ exercice_respiration.timeExpiration }}s</span>
                            <small style="opacity:0.75;">Expiration</small>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 d-flex gap-2 flex-wrap justify-content-center">
                    <a href="{{ path('app_exercice_respiration_launch', {id: exercice_respiration.id}) }}" class="btn btn-cesizen-primary btn-sm">
                        <i class="bi bi-play-fill me-1"></i> Lancer
                    </a>
                    <a href="{{ path('app_exercice_respiration_show', {id: exercice_respiration.id}) }}" class="btn btn-cesizen btn-sm">
                        <i class="bi bi-eye me-1"></i> Voir
                    </a>
                    <a href="{{ path('app_exercice_respiration_export_one', {id: exercice_respiration.id}) }}" class="btn btn-cesizen btn-sm">
                        <i class="bi bi-download me-1"></i> Exporter
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_exercice_respiration_edit', {id: exercice_respiration.id}) }}" class="btn btn-cesizen btn-sm">
                            <i class="bi bi-pencil me-1"></i> Modifier
                        </a>
                        <form method="post" action="{{ path('app_exercice_respiration_delete', {id: exercice_respiration.id}) }}"
                              onsubmit="return confirm('Supprimer cet exercice ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ exercice_respiration.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash me-1"></i> Supprimer
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

{% endblock %}