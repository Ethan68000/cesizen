{% extends 'base.html.twig' %}

{% block title %}Exercices de respiration — CESIZen{% endblock %}

{% block body %}

    <!-- Banner -->
    <div class="section-banner text-center">
        <h1 class="fw-bold fs-2"><i class="bi bi-lungs me-2"></i>Exercices de respiration</h1>
        <p class="mb-0 fs-5">Vous êtes sur la page des exercices, découvrez nos contenus</p>
    </div>

    <!-- Export / Import admin seulement -->
    {% if is_granted('ROLE_USER') %}
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <a href="{{ path('app_exercice_respiration_export') }}" class="btn btn-cesizen">
                <i class="bi bi-download me-1"></i> Exporter tout
            </a>
            <form method="post" action="{{ path('app_exercice_respiration_import') }}" enctype="multipart/form-data" class="d-flex gap-2 align-items-center">
                <label for="json_file" class="btn btn-cesizen mb-0" style="cursor:pointer;">
                    <i class="bi bi-folder2-open me-1"></i> Choisir un fichier JSON
                </label>
                <input type="file" name="json_file" id="json_file" accept=".json" required style="display:none;" onchange="this.nextElementSibling.textContent = this.files[0]?.name || 'Aucun fichier'">
                <span class="text-white small">Aucun fichier</span>
                <button type="submit" class="btn btn-cesizen">
                    <i class="bi bi-upload me-1"></i> Importer
                </button>
            </form>
        </div>
    </div>
    {% endif %}

    <!-- Exercices prédéfinis -->
    <h2 class="text-white fw-bold mb-3">
        <i class="bi bi-stars me-2"></i>Exercices prédéfinis
    </h2>
    <div class="row g-4 mb-5">
        {% for exercice in exercices_predefinis %}
        <div class="col-md-4">
            <div class="card card-cesizen h-100 p-3">
                <div class="card-body text-center">
                    <i class="bi bi-wind display-4 mb-2"></i>
                    <h5 class="fw-bold">{{ exercice.nameSeries }}</h5>
                    <div class="d-flex justify-content-around my-3">
                        <div>
                            <span class="d-block fs-4 fw-bold">{{ exercice.timeInspiration }}s</span>
                            <small style="opacity:0.75;">Inspiration</small>
                        </div>
                        {% if exercice.timeApnea > 0 %}
                        <div>
                            <span class="d-block fs-4 fw-bold">{{ exercice.timeApnea }}s</span>
                            <small style="opacity:0.75;">Apnée</small>
                        </div>
                        {% endif %}
                        <div>
                            <span class="d-block fs-4 fw-bold">{{ exercice.timeExpiration }}s</span>
                            <small style="opacity:0.75;">Expiration</small>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 d-flex gap-2 flex-wrap justify-content-center">
                    <a href="{{ path('app_exercice_respiration_launch', {id: exercice.id}) }}" class="btn btn-cesizen-primary btn-sm">
                        <i class="bi bi-play-fill me-1"></i> Lancer
                    </a>
                    <a href="{{ path('app_exercice_respiration_show', {id: exercice.id}) }}" class="btn btn-cesizen btn-sm">
                        <i class="bi bi-eye me-1"></i> Voir
                    </a>
                    <a href="{{ path('app_exercice_respiration_export_one', {id: exercice.id}) }}" class="btn btn-cesizen btn-sm">
                        <i class="bi bi-download me-1"></i> Exporter
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_exercice_respiration_edit', {id: exercice.id}) }}" class="btn btn-cesizen btn-sm">
                            <i class="bi bi-pencil me-1"></i> Modifier
                        </a>
                        <form method="post" action="{{ path('app_exercice_respiration_delete', {id: exercice.id}) }}"
                              onsubmit="return confirm('Supprimer cet exercice ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ exercice.id) }}">
                            <button type="submit" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash me-1"></i> Supprimer
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
        </div>
        {% endfor %}
    </div>

    <!-- Mes exercices -->
    <h2 class="text-white fw-bold mb-3">
        <i class="bi bi-person me-2"></i>Mes exercices
    </h2>

    {% if not app.user %}
        <div class="section-banner mb-4">
            <p class="mb-0 text-center">
                <i class="bi bi-info-circle me-1"></i>
                Vous n'êtes pas connecté. Vos exercices seront perdus à la fermeture du navigateur.
                <a href="{{ path('app_login') }}" class="text-white fw-bold">Connectez-vous</a> pour les sauvegarder !
            </p>
        </div>
    {% endif %}

    <div class="row g-4 mb-4">
        {% if mes_exercices is empty %}
            <div class="col-12">
                <div class="section-banner text-center">
                    <p class="mb-0">Aucun exercice pour le moment.</p>
                </div>
            </div>
        {% else %}
            {% for exercice in mes_exercices %}
            <div class="col-md-4">
                <div class="card card-cesizen h-100 p-3">
                    <div class="card-body text-center">
                        <i class="bi bi-wind display-4 mb-2"></i>
                        <h5 class="fw-bold">{{ exercice.nameSeries ?? exercice['nameSeries'] }}</h5>
                        <div class="d-flex justify-content-around my-3">
                            <div>
                                <span class="d-block fs-4 fw-bold">{{ exercice.timeInspiration ?? exercice['timeInspiration'] }}s</span>
                                <small style="opacity:0.75;">Inspiration</small>
                            </div>
                            {% set apnea = exercice.timeApnea ?? exercice['timeApnea'] %}
                            {% if apnea > 0 %}
                            <div>
                                <span class="d-block fs-4 fw-bold">{{ apnea }}s</span>
                                <small style="opacity:0.75;">Apnée</small>
                            </div>
                            {% endif %}
                            <div>
                                <span class="d-block fs-4 fw-bold">{{ exercice.timeExpiration ?? exercice['timeExpiration'] }}s</span>
                                <small style="opacity:0.75;">Expiration</small>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 d-flex gap-2 flex-wrap justify-content-center">
                        {% if app.user %}
                            <a href="{{ path('app_exercice_respiration_launch', {id: exercice.id}) }}" class="btn btn-cesizen-primary btn-sm">
                                <i class="bi bi-play-fill me-1"></i> Lancer
                            </a>
                            <a href="{{ path('app_exercice_respiration_show', {id: exercice.id}) }}" class="btn btn-cesizen btn-sm">
                                <i class="bi bi-eye me-1"></i> Voir
                            </a>
                            <a href="{{ path('app_exercice_respiration_export_one', {id: exercice.id}) }}" class="btn btn-cesizen btn-sm">
                                <i class="bi bi-download me-1"></i> Exporter
                            </a>
                            <a href="{{ path('app_exercice_respiration_edit', {id: exercice.id}) }}" class="btn btn-cesizen btn-sm">
                                <i class="bi bi-pencil me-1"></i> Modifier
                            </a>
                            <form method="post" action="{{ path('app_exercice_respiration_delete', {id: exercice.id}) }}"
                                  onsubmit="return confirm('Supprimer cet exercice ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ exercice.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash me-1"></i> Supprimer
                                </button>
                            </form>
                        {% else %}
                            <a href="{{ path('app_exercice_respiration_launch_session', {sessionId: exercice['id']}) }}" class="btn btn-cesizen-primary btn-sm">
                                <i class="bi bi-play-fill me-1"></i> Lancer
                            </a>
                            <a href="#" onclick="exportSession({{ exercice|json_encode }})" class="btn btn-cesizen btn-sm">
                                <i class="bi bi-download me-1"></i> Exporter
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endfor %}
        {% endif %}
    </div>

    <!-- Bouton créer -->
    <div class="text-center mt-2">
        <a href="{{ path('app_exercice_respiration_new') }}" class="btn btn-cesizen-primary px-5">
            <i class="bi bi-plus-circle me-2"></i> Créer un exercice
        </a>
    </div>

{% endblock %}

{% block javascripts %}
<script>
function exportSession(exercice) {
    const data = JSON.stringify([exercice]);
    const blob = new Blob([data], {type: 'application/json'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'exercice_' + exercice.id + '.json';
    a.click();
    URL.revokeObjectURL(url);
}
</script>
{% endblock %}